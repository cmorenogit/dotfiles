{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "engram": {
      "command": [
        "/opt/homebrew/Cellar/engram/1.12.0-beta.1/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    }
  },
  "plugin": [
    "opencode-anthropic-login-via-cli@latest",
    "opencode-gemini-auth@latest"
  ]
}
