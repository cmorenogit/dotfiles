{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_TEAMMATE_MODE": "tmux"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read(~/Code/work/**)",
      "Read(~/Code/personal/**)",
      "Write(~/Code/personal/**)",
      "Read(~/Code/_vault/**)",
      "Write(~/Code/_vault/**)",
      "mcp__obsidian__obsidian_append_content",
      "WebSearch",
      "Bash(tree:*)",
      "Bash(node -e:*)"
    ],
    "deny": [
      "Read(~/Code/_archive/**)",
      "Write(~/Code/_archive/**)"
    ],
    "ask": [],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__linear__save_.*|mcp__linear__delete_.*|mcp__linear__create_.*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/linear-write-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/vault-write-guard.py",
            "timeout": 10,
            "statusMessage": "Vault guard: validando destino..."
          }
        ]
      }
    ],
    "Stop": []
  },
  "statusLine": {
    "type": "command",
    "command": "/opt/homebrew/bin/bash \"$HOME/.claude/statusline-command.sh\""
  },
  "enabledPlugins": {
    "engram@engram": true,
    "worktrunk@worktrunk": true,
    "last30days@last30days-skill": true
  },
  "extraKnownMarketplaces": {
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    },
    "engram": {
      "source": {
        "source": "github",
        "repo": "Gentleman-Programming/engram"
      }
    },
    "last30days-skill": {
      "source": {
        "source": "github",
        "repo": "mvanhorn/last30days-skill"
      }
    }
  },
  "language": "Español",
  "alwaysThinkingEnabled": true,
  "disableArtifact": true,
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "preferredNotifChannel": "ghostty",
  "teammateMode": "tmux",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
