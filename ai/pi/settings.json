{
  "lastChangelogVersion": "0.80.6",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-sol",
  "defaultThinkingLevel": "high",
  "theme": "dark",
  "packages": [
    {
      "source": "npm:pi-powerline-footer",
      "extensions": [
        "+index.ts"
      ]
    },
    {
      "source": "npm:@hypabolic/pi-hypa",
      "extensions": [
        "-extensions/index.ts"
      ]
    },
    {
      "source": "npm:pi-web-access",
      "skills": [
        "+skills/librarian/SKILL.md"
      ]
    },
    "npm:gentle-engram",
    {
      "source": "npm:@ayulab/oh-my-pi",
      "themes": [
        "-themes/purple-dream.json"
      ]
    },
    "npm:@m4riok/pi-openai-tweaks"
  ],
  "enableSkillCommands": true,
  "showHardwareCursor": true,
  "enableInstallTelemetry": false,
  "defaultProjectTrust": "ask",
  "warnings": {
    "anthropicExtraUsage": true
  },
  "hideThinkingBlock": true,
  "skills": [
    "~/.dotfiles/ai/claude/skills/explica",
    "~/.dotfiles/ai/claude/skills/producto"
  ],
  "piOpenaiTweaks": {
    "format": "compact",
    "showWeekly": true,
    "percentMode": "used",
    "updateMode": "turn"
  },
  "images": {
    "autoResize": false
  },
  "outputPad": 0,
  "terminal": {
    "clearOnShrink": false
  }
}